{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [ { "type": "host", "value": "www.fretpilotstudio.com" } ],
      "destination": "https://fretpilotstudio.com/$1",
      "statusCode": 308
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "has": [{ "type": "host", "value": "thefranksstandard.com" }], "destination": "/store.html" },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.thefranksstandard.com" }], "destination": "/store.html" },
    { "source": "/store", "destination": "/store.html" },
    { "source": "/store/(.*)", "destination": "/store.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
